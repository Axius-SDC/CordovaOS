# Query 5: Family Economic Unit
# Given a person, find their Civil Registry record and all other records
# sharing the same National ID across domains.
# Input: Person's CID, e.g. "COR-AL01-271845"
#
# Note: Family relationship traversal requires the Relationship Type
# component. This query shows all records for the target person across
# all domains that carry the National ID component.

PREFIX sdc4: <https://semanticdatacharter.com/ns/sdc4/>
PREFIX rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX dc:   <http://purl.org/dc/elements/1.1/>

SELECT ?domain ?component_label ?value
WHERE {
  # Find all instances containing this CID across any domain
  ?cid_reifier sdc4:forComponent sdc4:mc-nj7s1gk45tfgyooxpz0qaha3 ;
               sdc4:componentValue "COR-AL01-271845" ;
               sdc4:inInstance ?instance ;
               sdc4:inDataModel ?dm .

  OPTIONAL { ?dm dc:title ?dm_title }
  BIND(COALESCE(?dm_title, REPLACE(STR(?dm), '.*/dm-', '')) AS ?domain)

  # Get all components from each instance
  ?comp_reifier sdc4:inInstance ?instance ;
                rdfs:label ?component_label ;
                sdc4:componentValue ?value .
}
ORDER BY ?domain ?component_label
LIMIT 500
