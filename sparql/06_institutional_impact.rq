# Query 6: Institutional Impact
# For an institution (via BRN), find all records in the Business Registry,
# then find students at the institution via Education records sharing
# the same city/province.
# Input: Institution BRN, e.g. "BIZ-000847" (Universidad Nacional de Cordova)
#
# Join mechanism: BRN links to Business Registry; Education records in
# the same city show the institutional footprint.

PREFIX sdc4: <https://semanticdatacharter.com/ns/sdc4/>
PREFIX rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT ?category ?detail_label ?detail_value
WHERE {
  {
    # Business Registry details for the institution
    ?brn_reifier rdf:reifies << sdc4:mc-l8f0m7op4xhrxqy1jrnvbuly sdc4:xdstring-value "BIZ-000847" >> ;
                 sdc4:inInstance ?biz_inst ;
                 sdc4:inDataModel sdc4:dm-x250838l7oi6l3yavg9twc1i .

    ?comp_reifier sdc4:inInstance ?biz_inst ;
                  rdfs:label ?detail_label ;
                  rdf:reifies << ?subj ?pred ?detail_value >> .

    BIND("Business Registry" AS ?category)
  }
  UNION
  {
    # Education records (students/faculty)
    ?edu_reifier sdc4:inInstance ?edu_inst ;
                 sdc4:inDataModel sdc4:dm-upq7w1bqbix5v5ss0mu3kq5n ;
                 rdfs:label ?detail_label ;
                 rdf:reifies << ?subj ?pred ?detail_value >> .

    BIND("Education Record" AS ?category)
  }
}
ORDER BY ?category ?detail_label
