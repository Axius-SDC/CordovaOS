# Query 2: Economic Network Analysis
# Trace the economic network around a business: employees, tax filings,
# port shipments, and business details.
# Input: Business Registry Number, e.g. "BIZ-001102"
#
# Join mechanism: Shared component mc-l8f0m7op4xhrxqy1jrnvbuly (BRN)
# links Business Registry and Maritime. Employment linked via employer
# party-id pattern (not yet in RDF). Shows all records containing BRN.

PREFIX sdc4: <https://semanticdatacharter.com/ns/sdc4/>
PREFIX rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX dc:   <http://purl.org/dc/elements/1.1/>

SELECT ?domain ?component_label ?value
WHERE {
  # Find instances containing this BRN
  ?brn_reifier rdf:reifies << sdc4:mc-l8f0m7op4xhrxqy1jrnvbuly sdc4:xdstring-value "BIZ-001102" >> ;
               sdc4:inInstance ?instance ;
               sdc4:inDataModel ?dm .

  OPTIONAL { ?dm dc:title ?dm_title }
  BIND(COALESCE(?dm_title, REPLACE(STR(?dm), '.*/dm-', '')) AS ?domain)

  # Get all components from the same instance
  ?comp_reifier sdc4:inInstance ?instance ;
                rdfs:label ?component_label ;
                rdf:reifies << ?subj ?pred ?value >> .
}
ORDER BY ?domain ?component_label
