# Query 1: Complete Government Profile
# All government touchpoints for a single person across all domains.
# Input: National ID (CID) value, e.g. "COR-AL01-271845"
#
# Join mechanism: Shared component ct_id mc-nj7s1gk45tfgyooxpz0qaha3
# (National ID) appears in Civil Registry, Vital Statistics, Healthcare,
# and Education. Other domains joined via City/Province shared components.

PREFIX sdc4: <https://semanticdatacharter.com/ns/sdc4/>
PREFIX rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX dc:   <http://purl.org/dc/elements/1.1/>

SELECT ?domain ?component_label ?value
WHERE {
  # Find instances containing this person's National ID
  ?cid_reifier sdc4:forComponent sdc4:mc-nj7s1gk45tfgyooxpz0qaha3 ;
               sdc4:componentValue "COR-AL01-271845" ;
               sdc4:inInstance ?instance ;
               sdc4:inDataModel ?dm .

  # Get domain name
  BIND(REPLACE(STR(?dm), '.*/dm-', '') AS ?dm_id)
  OPTIONAL { ?dm dc:title ?dm_title }
  BIND(COALESCE(?dm_title, ?dm_id) AS ?domain)

  # Get all components from the same instance
  ?comp_reifier sdc4:inInstance ?instance ;
                rdfs:label ?component_label ;
                sdc4:componentValue ?value .
}
ORDER BY ?domain ?component_label
LIMIT 500
