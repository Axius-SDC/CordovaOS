# Application Name
APP_NAME=sdc4

# Ports — offset from defaults to avoid conflicts with other local services.
# Max valid port is 65535. Adjust if these collide with anything on your machine.

# Database (PostgreSQL)
# Default username: admin
# Default password: admin123 (change in production!)
DB_PASSWORD=admin123
DB_PORT=15432

# GraphDB (OWL 2 Reasoning Triplestore)
# Web UI: http://localhost:17200
# Default username: admin
# Default password: admin123 (change in production!)
GRAPHDB_PORT=17200
GRAPHDB_USER=admin
GRAPHDB_PASSWORD=admin123

# SirixDB (Temporal JSON/XML Database)
# Default username: admin
# Default password: admin123 (change in production!)
SIRIX_PORT=19443
SIRIX_USER=admin
SIRIX_PASSWORD=admin123

# Keycloak (SSO/RBAC Authentication)
# Admin console: http://localhost:18080/admin
# Default username: admin
# Default password: admin123 (change in production!)
KEYCLOAK_PORT=18080
KEYCLOAK_PASSWORD=admin123
KEYCLOAK_CLIENT_SECRET=changeme

# Redis (Celery Message Broker)
REDIS_PORT=16379

# Django Web
WEB_PORT=18000

# Django
SECRET_KEY=changeme-generate-secure-key-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
