    <sdc4-meta:isConstrainedByRmComponent rdf:resource="sdc4:XdFileType"/>
    <rdfs:label>Business Registry Attested View</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="https://schema.org/DigitalDocument"/>
  </rdf:Description>
