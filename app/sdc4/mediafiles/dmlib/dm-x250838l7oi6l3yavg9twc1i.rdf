  <rdf:Description rdf:about="sdc4:mc-dr8983b4k8ngg02x78lrw560">
    <rdf:type rdf:resource="sdc4-meta:ModelComponent"/>
    <sdc4-meta:isConstrainedByRmComponent rdf:resource="sdc4:XdStringType"/>
    <rdfs:label>Business Registration Protocol</rdfs:label>
    <rdfs:comment>Protocol reference for the Business Registry data model. Informed by the UNCITRAL Model Law on Business Registries, national commercial registration codes, and the UN/CEFACT Core Component Library for standardized business entity representation.</rdfs:comment>
    <sdc4-meta:describesConceptualEntity rdf:resource="sdc4:concept-business_registration_protocol"/>
    <rdfs:isDefinedBy rdf:resource="https://www.wikidata.org/wiki/Q132364"/>
    <rdfs:seeAlso rdf:resource="https://www.wikidata.org/wiki/Q483908"/>
  </rdf:Description>
