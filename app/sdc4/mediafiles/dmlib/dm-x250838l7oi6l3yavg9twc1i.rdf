  <rdf:Description rdf:about="sdc4:mc-gu15c6jojx09jy9at1px0ufh">
    <rdf:type rdf:resource="sdc4-meta:ModelComponent"/>
    <rdf:type rdf:resource="https://schema.org/Text"/>
    <sdc4-meta:isConstrainedByRmComponent rdf:resource="sdc4:XdStringType"/>
    <rdfs:label>Organization Tax ID</rdfs:label>
    <rdfs:comment>A tax identification number (TIN/EIN) for an organization (NIEM nc:OrganizationTaxIdentification)</rdfs:comment>
    <sdc4-meta:describesConceptualEntity rdf:resource="sdc4:concept-organization_tax_id"/>
    <rdfs:isDefinedBy rdf:resource="https://www.wikidata.org/wiki/Q2397748"/>
  </rdf:Description>
  <rdf:Description rdf:about="sdc4:mc-nfrvvp87c5imu5h9ups92kgy">
    <rdf:type rdf:resource="sdc4-meta:ModelComponent"/>
    <sdc4-meta:isConstrainedByRmComponent rdf:resource="sdc4:XdStringType"/>
    <rdfs:label>Cordova Phone Number</rdfs:label>
    <rdfs:comment>Cordova national telephone number. Format: +99-PPP-NNN-NNNN where +99 is the country code and PPP is the area code. Area codes: Porto Sereno=100, Vistamar=110, Rioseco=120, Campoluz=200, Tierraverde=210, Montecara=220, Novaciudad=300, Piedrasol=310, Lagunavista=320.</rdfs:comment>
    <sdc4-meta:describesConceptualEntity rdf:resource="sdc4:concept-cordova_phone_number"/>
    <rdfs:isDefinedBy rdf:resource="https://www.wikidata.org/wiki/Q214995"/>
  </rdf:Description>
  <rdf:Description rdf:about="sdc4:mc-d79vg5e2e4nnoxontodl9co7">
    <rdf:type rdf:resource="sdc4-meta:ModelComponent"/>
    <sdc4-meta:isConstrainedByRmComponent rdf:resource="sdc4:PartyType"/>
    <rdfs:label>Business Officer</rdfs:label>
    <rdfs:comment>Person acting as an officer of a business entity (director, secretary, etc.). W3C PROV-DM Agent (Person) with appointment lifecycle.</rdfs:comment>
    <sdc4-meta:describesConceptualEntity rdf:resource="sdc4:concept-business_officer"/>
    <rdfs:isDefinedBy rdf:resource="https://www.wikidata.org/wiki/Q11488158"/>
    <rdfs:isDefinedBy rdf:resource="https://schema.org/Person"/>
    <rdfs:isDefinedBy rdf:resource="http://www.w3.org/ns/prov#Agent"/>
  </rdf:Description>
  <rdf:Description rdf:about="sdc4:mc-uinddfbzfk0jdikmt1jwcq78">
    <rdf:type rdf:resource="sdc4-meta:ModelComponent"/>
    <rdf:type rdf:resource="https://schema.org/Text"/>
    <sdc4-meta:isConstrainedByRmComponent rdf:resource="sdc4:XdStringType"/>
    <rdfs:label>Organization Name</rdfs:label>
    <rdfs:comment>A name of an organization (NIEM nc:OrganizationName). BFO alignment: organization is a material entity (BFO:0000040) that is a collection of persons organized for a purpose.</rdfs:comment>
    <sdc4-meta:describesConceptualEntity rdf:resource="sdc4:concept-organization_name"/>
    <rdfs:isDefinedBy rdf:resource="https://www.wikidata.org/wiki/Q168678"/>
  </rdf:Description>
  <rdf:Description rdf:about="sdc4:mc-uizvwh8uzojpwcih36rmk9ed">
    <rdf:type rdf:resource="sdc4-meta:ModelComponent"/>
    <sdc4-meta:isConstrainedByRmComponent rdf:resource="sdc4:XdTemporalType"/>
    <rdfs:label>Resignation Date</rdfs:label>
    <rdfs:comment>Date the officer resigned or was removed. Null for current officers.</rdfs:comment>
    <sdc4-meta:describesConceptualEntity rdf:resource="sdc4:concept-resignation_date"/>
    <rdfs:isDefinedBy rdf:resource="https://www.wikidata.org/wiki/Q121875611"/>
  </rdf:Description>
