    <rdfs:isDefinedBy rdf:resource="https://niemopen.org/"/>
    <rdfs:isDefinedBy rdf:resource="http://www.w3.org/ns/prov#Agent"/>
  </rdf:Description>
  <rdf:Description rdf:about="sdc4:mc-pndsgg7zczz4bgnmh11g40ka">
