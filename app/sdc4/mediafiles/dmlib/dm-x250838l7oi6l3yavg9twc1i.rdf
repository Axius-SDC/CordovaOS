    <sdc4-meta:isConstrainedByRmComponent rdf:resource="sdc4:PartyType"/>
    <rdfs:label>Business Registry Office</rdfs:label>
    <rdfs:comment>Government office responsible for maintaining the national business registry. W3C PROV-DM Agent (Organization).</rdfs:comment>
    <sdc4-meta:describesConceptualEntity rdf:resource="sdc4:concept-business_registry_office"/>
    <rdfs:isDefinedBy rdf:resource="https://www.wikidata.org/wiki/Q1423020"/>
    <rdfs:isDefinedBy rdf:resource="http://schema.org/GovernmentOrganization"/>
    <rdfs:isDefinedBy rdf:resource="https://schema.org/Organization"/>
    <rdfs:isDefinedBy rdf:resource="http://www.w3.org/ns/prov#Agent"/>
  </rdf:Description>
