  <rdf:Description rdf:about="sdc4:mc-l8f0m7op4xhrxqy1jrnvbuly">
    <rdf:type rdf:resource="sdc4-meta:ModelComponent"/>
    <sdc4-meta:isConstrainedByRmComponent rdf:resource="sdc4:XdStringType"/>
    <rdfs:label>Business Registry Number</rdfs:label>
    <rdfs:comment>Cordova Business Registration Number. Format: BIZ-NNNNNN where NNNNNN is a six-digit sequence number assigned at incorporation. Required for all business filings, tax records, and port authority transactions.</rdfs:comment>
    <sdc4-meta:describesConceptualEntity rdf:resource="sdc4:concept-business_registry_number"/>
    <rdfs:isDefinedBy rdf:resource="https://www.wikidata.org/wiki/Q12047291"/>
    <rdfs:isDefinedBy rdf:resource="http://schema.org/identifier"/>
  </rdf:Description>
  <rdf:Description rdf:about="sdc4:mc-a3v5ezi7h5cb7e0jkumtxtbm">
    <rdf:type rdf:resource="sdc4-meta:ModelComponent"/>
    <sdc4-meta:isConstrainedByRmComponent rdf:resource="sdc4:XdTemporalType"/>
    <rdfs:label>Appointment Date</rdfs:label>
    <rdfs:comment>Date the officer was appointed to their role</rdfs:comment>
    <sdc4-meta:describesConceptualEntity rdf:resource="sdc4:concept-appointment_date"/>
    <rdfs:isDefinedBy rdf:resource="https://www.wikidata.org/wiki/Q96105089"/>
  </rdf:Description>
  <rdf:Description rdf:about="sdc4:mc-sxtoz5f7z2jbvckaczaetrto">
    <rdf:type rdf:resource="sdc4-meta:ModelComponent"/>
    <sdc4-meta:isConstrainedByRmComponent rdf:resource="sdc4:AttestationType"/>
    <rdfs:label>Business Registry Attestation</rdfs:label>
    <rdfs:comment>Attestation for business registration records. The registry office attests to the validity of the business entity registration. W3C PROV-DM, GDPR/UN CEB.</rdfs:comment>
    <sdc4-meta:describesConceptualEntity rdf:resource="sdc4:concept-business_registry_attestation"/>
    <rdfs:isDefinedBy rdf:resource="https://www.wikidata.org/wiki/Q116890704"/>
    <rdfs:isDefinedBy rdf:resource="https://www.w3.org/TR/vc-data-model/#credentials"/>
    <rdfs:isDefinedBy rdf:resource="http://www.w3.org/ns/prov#Activity"/>
    <rdfs:seeAlso rdf:resource="https://www.wikidata.org/wiki/Q4830453"/>
  </rdf:Description>
  <rdf:Description rdf:about="sdc4:mc-kwf6pkljihy5mqd9h3bgie39">
