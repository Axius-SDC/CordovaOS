  <rdf:Description rdf:about="sdc4:mc-kokquuk73pm2ohlh4ftnu7wb">
    <rdf:type rdf:resource="sdc4-meta:ModelComponent"/>
    <sdc4-meta:isConstrainedByRmComponent rdf:resource="sdc4:XdQuantityType"/>
    <rdfs:label>Systolic Blood Pressure</rdfs:label>
    <rdfs:comment>Peak arterial pressure during cardiac contraction, measured in mmHg. Normal adult range is 90–120 mmHg. Values ≥140 mmHg indicate hypertension per WHO/AHA guidelines.</rdfs:comment>
  </rdf:Description>
