    <sdc4-meta:isConstrainedByRmComponent rdf:resource="sdc4:XdTokenType"/>
    <rdfs:label>Province</rdfs:label>
    <rdfs:comment>One of the three provinces of the Republic of Cordova. Used across civil registry, property, tax, and all geographic records.</rdfs:comment>
