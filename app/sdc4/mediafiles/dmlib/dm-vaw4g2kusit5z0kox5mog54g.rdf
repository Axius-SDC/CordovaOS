  <rdf:Description rdf:about="sdc4:mc-z8bsecpgj1lsk4bjoiwaqn40">
    <rdf:type rdf:resource="sdc4-meta:ModelComponent"/>
    <sdc4-meta:isConstrainedByRmComponent rdf:resource="sdc4:XdStringType"/>
    <rdfs:label>Tax Records Protocol</rdfs:label>
    <rdfs:comment>Protocol reference for the Tax and Revenue Record data model. Informed by the OECD Common Reporting Standard (CRS) for automatic exchange of financial account information, the Standard for Automatic Exchange of Financial Account Information in Tax Matters, and national tax administration frameworks.</rdfs:comment>
    <sdc4-meta:describesConceptualEntity rdf:resource="sdc4:concept-tax_records_protocol"/>
    <rdfs:isDefinedBy rdf:resource="https://www.wikidata.org/wiki/Q132364"/>
    <rdfs:seeAlso rdf:resource="https://www.wikidata.org/wiki/Q7842"/>
  </rdf:Description>
