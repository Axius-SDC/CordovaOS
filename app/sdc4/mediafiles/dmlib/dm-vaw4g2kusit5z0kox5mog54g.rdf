  <rdf:Description rdf:about="sdc4:mc-q1sbdhsdk8glmdr8q1x3mlte">
    <rdf:type rdf:resource="sdc4-meta:ModelComponent"/>
    <sdc4-meta:isConstrainedByRmComponent rdf:resource="sdc4:XdQuantityType"/>
    <rdfs:label>Taxable Income</rdfs:label>
    <rdfs:comment>Gross income minus allowable deductions for the filing period in Cordova Córdoba. Serves as the base amount for tax rate application.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="sdc4:mc-tzrg36a15rigk48nj20sbw4v">
    <rdf:type rdf:resource="sdc4-meta:ModelComponent"/>
    <sdc4-meta:isConstrainedByRmComponent rdf:resource="sdc4:XdQuantityType"/>
    <rdfs:label>Payment Amount</rdfs:label>
    <rdfs:comment>Tax payment amount received in Cordova Córdoba. Records the actual amount remitted by the taxpayer for a specific tax filing period.</rdfs:comment>
  </rdf:Description>
