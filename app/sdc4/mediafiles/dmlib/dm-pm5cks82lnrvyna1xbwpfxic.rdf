  <rdf:Description rdf:about="sdc4:mc-dqjp4dd4kgj2e2hg8kiw3qfw">
    <rdf:type rdf:resource="sdc4-meta:ModelComponent"/>
    <sdc4-meta:isConstrainedByRmComponent rdf:resource="sdc4:AttestationType"/>
    <rdfs:label>Employment Record Attestation</rdfs:label>
    <rdfs:comment>Attestation for employment records. The employer attests to employment status, role, and dates. W3C PROV-DM, GDPR/UN CEB.</rdfs:comment>
    <sdc4-meta:describesConceptualEntity rdf:resource="sdc4:concept-employment_record_attestation"/>
    <rdfs:isDefinedBy rdf:resource="https://www.wikidata.org/wiki/Q116890704"/>
    <rdfs:isDefinedBy rdf:resource="https://www.w3.org/TR/vc-data-model/#credentials"/>
    <rdfs:isDefinedBy rdf:resource="http://www.w3.org/ns/prov#Activity"/>
