  <rdf:Description rdf:about="sdc4:mc-e92ud8io69rm826g9b1jrrgh">
    <rdf:type rdf:resource="sdc4-meta:ModelComponent"/>
    <sdc4-meta:isConstrainedByRmComponent rdf:resource="sdc4:XdQuantityType"/>
    <rdfs:label>Port Fee Amount</rdfs:label>
    <rdfs:comment>Fee amount assessed for port services in Cordova Córdoba. Includes berth rental, pilotage, tug assistance, waste disposal, and other harbor charges per the Porto Sereno fee schedule.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="sdc4:mc-kmd0ncqu6c70mt5ri4bxucgg">
    <rdf:type rdf:resource="sdc4-meta:ModelComponent"/>
    <sdc4-meta:isConstrainedByRmComponent rdf:resource="sdc4:AttestationType"/>
    <rdfs:label>Maritime Attestation</rdfs:label>
    <rdfs:comment>Attestation for maritime port records. The port authority attests to vessel arrival/departure data and crew manifests. W3C PROV-DM, GDPR/UN CEB.</rdfs:comment>
    <sdc4-meta:describesConceptualEntity rdf:resource="sdc4:concept-maritime_attestation"/>
    <rdfs:isDefinedBy rdf:resource="https://www.wikidata.org/wiki/Q116890704"/>
    <rdfs:isDefinedBy rdf:resource="https://www.w3.org/TR/vc-data-model/#credentials"/>
    <rdfs:isDefinedBy rdf:resource="http://www.w3.org/ns/prov#Activity"/>
    <rdfs:seeAlso rdf:resource="https://www.wikidata.org/wiki/Q949149"/>
  </rdf:Description>
