  <rdf:Description rdf:about="sdc4:mc-x720xrlooqij75bk26pvzrtl">
    <rdf:type rdf:resource="sdc4-meta:ModelComponent"/>
    <rdf:type rdf:resource="https://schema.org/Integer"/>
    <sdc4-meta:isConstrainedByRmComponent rdf:resource="sdc4:XdCountType"/>
    <rdfs:label>Passenger Count</rdfs:label>
    <rdfs:comment>Total number of passengers aboard the vessel at time of port call. Required for immigration processing, disembarkation planning, and port facility capacity management. Zero for cargo-only vessels.</rdfs:comment>
    <sdc4-meta:describesConceptualEntity rdf:resource="sdc4:concept-passenger_count"/>
    <sdc4-meta:hasUnit rdf:resource="sdc4:mc-qb5xnfq8e7qzlxr2q1sc5qhy"/>
    <rdfs:isDefinedBy rdf:resource="https://www.wikidata.org/wiki/Q319604"/>
  </rdf:Description>
  <rdf:Description rdf:about="sdc4:mc-p5qzw565y1dm5f3s6lg2q3ft">
    <rdf:type rdf:resource="sdc4-meta:ModelComponent"/>
    <rdf:type rdf:resource="https://schema.org/Integer"/>
    <sdc4-meta:isConstrainedByRmComponent rdf:resource="sdc4:XdCountType"/>
    <rdfs:label>Crew Count</rdfs:label>
    <rdfs:comment>Total number of crew members aboard the vessel at time of port call. Required for immigration processing, shore leave management, and emergency muster planning.</rdfs:comment>
    <sdc4-meta:describesConceptualEntity rdf:resource="sdc4:concept-crew_count"/>
    <sdc4-meta:hasUnit rdf:resource="sdc4:mc-qb5xnfq8e7qzlxr2q1sc5qhy"/>
    <rdfs:isDefinedBy rdf:resource="https://www.wikidata.org/wiki/Q2513968"/>
  </rdf:Description>
