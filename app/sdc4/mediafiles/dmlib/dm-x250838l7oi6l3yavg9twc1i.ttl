<sdc4:mc-l8f0m7op4xhrxqy1jrnvbuly> a <sdc4-meta:ModelComponent> ;
    rdfs:label "Business Registry Number" ;
    rdfs:comment "Cordova Business Registration Number. Format: BIZ-NNNNNN where NNNNNN is a six-digit sequence number assigned at incorporation. Required for all business filings, tax records, and port authority transactions." ;
    rdfs:isDefinedBy <http://schema.org/identifier>,
        <https://www.wikidata.org/wiki/Q12047291> ;
    sdc4-meta:describesConceptualEntity <sdc4:concept-business_registry_number> ;
    sdc4-meta:isConstrainedByRmComponent <sdc4:XdStringType> .

<sdc4:mc-ndvtjiq0cke0q1trw58rtrq2> a schema:Text,
        <sdc4-meta:ModelComponent> ;
    rdfs:label "person_given_name" ;
    rdfs:comment "Given (first) name of the person agent." ;
    rdfs:isDefinedBy <https://www.wikidata.org/wiki/Q202444> ;
    sdc4-meta:describesConceptualEntity <sdc4:concept-person_given_name> ;
    sdc4-meta:isConstrainedByRmComponent <sdc4:XdStringType> .

<sdc4:mc-nfrvvp87c5imu5h9ups92kgy> a <sdc4-meta:ModelComponent> ;
    rdfs:label "Cordova Phone Number" ;
    rdfs:comment "Cordova national telephone number. Format: +99-PPP-NNN-NNNN where +99 is the country code and PPP is the area code. Area codes: Porto Sereno=100, Vistamar=110, Rioseco=120, Campoluz=200, Tierraverde=210, Montecara=220, Novaciudad=300, Piedrasol=310, Lagunavista=320." ;
    rdfs:isDefinedBy <https://www.wikidata.org/wiki/Q214995> ;
    sdc4-meta:describesConceptualEntity <sdc4:concept-cordova_phone_number> ;
    sdc4-meta:isConstrainedByRmComponent <sdc4:XdStringType> .

<sdc4:mc-nj7s1gk45tfgyooxpz0qaha3> a <sdc4-meta:ModelComponent> ;
    rdfs:label "National ID (CID)" ;
    rdfs:comment "Cordova National Identity Number. Format: COR-PPCC-NNNNNN where PP is the two-letter province code (AL=Aldara, BR=Brevina, CE=Celara), CC is the two-digit city code (01-03), and NNNNNN is a six-digit sequence number. Issued at birth or naturalization. Required for all government transactions." ;
    rdfs:isDefinedBy <http://schema.org/identifier>,
        <https://www.wikidata.org/wiki/Q1140371> ;
    sdc4-meta:describesConceptualEntity <sdc4:concept-national_id_(cid)> ;
    sdc4-meta:isConstrainedByRmComponent <sdc4:XdStringType> .

<sdc4:mc-oeh0dgfy3cytw829hkvuhjzv> a <sdc4-meta:ModelComponent> ;
    rdfs:label "Business Registry Attestation Reason" ;
    rdfs:comment "Reason for attesting this business registration" ;
    rdfs:isDefinedBy <https://www.wikidata.org/wiki/Q132364> ;
    sdc4-meta:describesConceptualEntity <sdc4:concept-business_registry_attestation_reason> ;
    sdc4-meta:isConstrainedByRmComponent <sdc4:XdStringType> .

<sdc4:mc-pndsgg7zczz4bgnmh11g40ka> a <sdc4-meta:ModelComponent> ;
    rdfs:label "Business Registry Office" ;
    rdfs:comment "Government office responsible for maintaining the national business registry. W3C PROV-DM Agent (Organization)." ;
    rdfs:isDefinedBy <http://schema.org/GovernmentOrganization>,
        prov:Agent,
        schema:Organization,
        <https://www.wikidata.org/wiki/Q1423020> ;
    sdc4-meta:describesConceptualEntity <sdc4:concept-business_registry_office> ;
    sdc4-meta:isConstrainedByRmComponent <sdc4:PartyType> .

