    rdfs:isDefinedBy prov:Activity,
        <https://niemopen.org/> ;
    sdc4-meta:isConstrainedByRmComponent <sdc4:ClusterType> .

<sdc4:mc-sxtoz5f7z2jbvckaczaetrto> a <sdc4-meta:ModelComponent> ;
    rdfs:label "Business Registry Attestation" ;
    rdfs:comment "Attestation for business registration records. The registry office attests to the validity of the business entity registration. W3C PROV-DM, GDPR/UN CEB." ;
    rdfs:isDefinedBy prov:Activity,
        <https://www.w3.org/TR/vc-data-model/#credentials>,
        <https://www.wikidata.org/wiki/Q116890704> ;
    rdfs:seeAlso <https://www.wikidata.org/wiki/Q4830453> ;
    sdc4-meta:describesConceptualEntity <sdc4:concept-business_registry_attestation> ;
    sdc4-meta:isConstrainedByRmComponent <sdc4:AttestationType> .

