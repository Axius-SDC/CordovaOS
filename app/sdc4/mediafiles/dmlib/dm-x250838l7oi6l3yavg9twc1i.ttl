<sdc4:mc-dr8983b4k8ngg02x78lrw560> a <sdc4-meta:ModelComponent> ;
    rdfs:label "Business Registration Protocol" ;
    rdfs:comment "Protocol reference for the Business Registry data model. Informed by the UNCITRAL Model Law on Business Registries, national commercial registration codes, and the UN/CEFACT Core Component Library for standardized business entity representation." ;
    rdfs:isDefinedBy <https://www.wikidata.org/wiki/Q132364> ;
    rdfs:seeAlso <https://www.wikidata.org/wiki/Q483908> ;
    sdc4-meta:describesConceptualEntity <sdc4:concept-business_registration_protocol> ;
    sdc4-meta:isConstrainedByRmComponent <sdc4:XdStringType> .

