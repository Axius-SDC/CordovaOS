    <rdfs:comment>name typically used to differentiate people from the same family, clan, or other social group who have a common last name
aka. first name or forename</rdfs:comment>
    <sdc4-meta:describesConceptualEntity rdf:resource="sdc4:concept-given_name_(person)"/>
