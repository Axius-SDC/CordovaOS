  <rdf:Description rdf:about="sdc4:mc-k9ptlhkq3j41p6umlg3tc80x">
    <rdf:type rdf:resource="sdc4-meta:ModelComponent"/>
    <sdc4-meta:isConstrainedByRmComponent rdf:resource="sdc4:XdTemporalType"/>
    <rdfs:label>Relationship Start Date</rdfs:label>
    <rdfs:comment>Date the relationship was established or recorded (e.g., marriage date, birth date of child, guardianship order date)

---</rdfs:comment>
    <sdc4-meta:describesConceptualEntity rdf:resource="sdc4:concept-relationship_start_date"/>
    <rdfs:isDefinedBy rdf:resource="https://www.wikidata.org/wiki/Q3406134"/>
  </rdf:Description>
  <rdf:Description rdf:about="sdc4:mc-nj7s1gk45tfgyooxpz0qaha3">
    <rdf:type rdf:resource="sdc4-meta:ModelComponent"/>
    <sdc4-meta:isConstrainedByRmComponent rdf:resource="sdc4:XdStringType"/>
    <rdfs:label>National ID (CID)</rdfs:label>
    <rdfs:comment>Cordova National Identity Number. Format: COR-PPCC-NNNNNN where PP is the two-letter province code (AL=Aldara, BR=Brevina, CE=Celara), CC is the two-digit city code (01-03), and NNNNNN is a six-digit sequence number. Issued at birth or naturalization. Required for all government transactions.</rdfs:comment>
    <sdc4-meta:describesConceptualEntity rdf:resource="sdc4:concept-national_id_(cid)"/>
    <rdfs:isDefinedBy rdf:resource="http://schema.org/identifier"/>
    <rdfs:isDefinedBy rdf:resource="https://www.wikidata.org/wiki/Q1140371"/>
  </rdf:Description>
  <rdf:Description rdf:about="sdc4:mc-o7vjxwswi0pxo543hq504jjx">
    <rdf:type rdf:resource="sdc4-meta:ModelComponent"/>
    <sdc4-meta:isConstrainedByRmComponent rdf:resource="sdc4:XdTemporalType"/>
    <rdfs:label>Relationship End Date</rdfs:label>
    <rdfs:comment>Date the relationship ended, if applicable (e.g., divorce date, death date). Null for active relationships.</rdfs:comment>
    <sdc4-meta:describesConceptualEntity rdf:resource="sdc4:concept-relationship_end_date"/>
    <rdfs:isDefinedBy rdf:resource="https://www.wikidata.org/wiki/Q121875611"/>
  </rdf:Description>
  <rdf:Description rdf:about="sdc4:mc-pf1mrtzd9ld1939qanem0olk">
    <rdf:type rdf:resource="sdc4-meta:ModelComponent"/>
    <sdc4-meta:isConstrainedByRmComponent rdf:resource="sdc4:AttestationType"/>
    <rdfs:label>Civil Registry Attestation</rdfs:label>
    <rdfs:comment>Attestation for civil registry records (births, marriages, name changes). The civil registry office attests to record accuracy. W3C PROV-DM, GDPR/UN CEB.</rdfs:comment>
    <sdc4-meta:describesConceptualEntity rdf:resource="sdc4:concept-civil_registry_attestation"/>
    <rdfs:isDefinedBy rdf:resource="https://www.wikidata.org/wiki/Q116890704"/>
    <rdfs:isDefinedBy rdf:resource="https://www.w3.org/TR/vc-data-model/#credentials"/>
    <rdfs:isDefinedBy rdf:resource="http://www.w3.org/ns/prov#Activity"/>
    <rdfs:seeAlso rdf:resource="https://www.wikidata.org/wiki/Q12047392"/>
  </rdf:Description>
