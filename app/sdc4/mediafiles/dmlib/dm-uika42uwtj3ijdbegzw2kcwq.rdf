    <rdfs:label>Birth Date</rdfs:label>
    <rdfs:comment>Date of birth of the participant. UMLS CUI: C0421451 (Date of birth). LOINC: 21112-8 (Birth date).</rdfs:comment>
    <sdc4-meta:describesConceptualEntity rdf:resource="sdc4:concept-birth_date"/>
    <rdfs:isDefinedBy rdf:resource="https://www.wikidata.org/wiki/Q2389905"/>
  </rdf:Description>
