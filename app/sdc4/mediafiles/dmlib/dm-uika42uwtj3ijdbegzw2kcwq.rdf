    <sdc4-meta:isConstrainedByRmComponent rdf:resource="sdc4:XdStringType"/>
    <rdfs:label>Civil Registration Protocol</rdfs:label>
    <rdfs:comment>Protocol reference for the Civil Registry data model. Informed by the United Nations Guidelines on Civil Registration and Vital Statistics Systems, the Handbook on Civil Registration and Vital Statistics (UN Statistics Division), and regional civil code frameworks.</rdfs:comment>
    <sdc4-meta:describesConceptualEntity rdf:resource="sdc4:concept-civil_registration_protocol"/>
    <rdfs:isDefinedBy rdf:resource="https://www.wikidata.org/wiki/Q132364"/>
