    <sdc4-meta:isConstrainedByRmComponent rdf:resource="sdc4:XdStringType"/>
    <rdfs:label>Surname (Person)</rdfs:label>
    <rdfs:comment>The surname or family name of a person, part of a naming scheme for individuals, used in many cultures worldwide
aka: last name, fam name, family surname, surname, clan name</rdfs:comment>
    <sdc4-meta:describesConceptualEntity rdf:resource="sdc4:concept-surname_(person)"/>
    <rdfs:isDefinedBy rdf:resource="https://www.wikidata.org/wiki/Q101352"/>
