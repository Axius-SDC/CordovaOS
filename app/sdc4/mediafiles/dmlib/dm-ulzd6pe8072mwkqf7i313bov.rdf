    <rdfs:label>Officiant</rdfs:label>
    <rdfs:comment>Person officiating a marriage ceremony (judge, clergy, etc.). W3C PROV-DM Agent (Person).</rdfs:comment>
    <sdc4-meta:describesConceptualEntity rdf:resource="sdc4:concept-officiant"/>
    <rdfs:isDefinedBy rdf:resource="https://www.wikidata.org/wiki/Q1708100"/>
    <rdfs:isDefinedBy rdf:resource="https://schema.org/Person"/>
    <rdfs:isDefinedBy rdf:resource="http://www.w3.org/ns/prov#Agent"/>
  </rdf:Description>
